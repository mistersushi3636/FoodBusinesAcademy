[Unit]
Description=MR.SUSHI Findir Dashboard (FastAPI)
After=network.target

[Service]
Type=simple
User=root
WorkingDirectory=/opt/fba/vault/apps/findir-dashboard
EnvironmentFile=/opt/fba/.env
Environment=PYTHONPATH=/opt/fba/vault/apps/findir-dashboard
ExecStart=/opt/fba/venvs/findir-dashboard/bin/uvicorn main:app --host 127.0.0.1 --port 8002
Restart=on-failure
RestartSec=5
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
